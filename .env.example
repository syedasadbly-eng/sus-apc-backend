# ============================================
# SUS APC Backend — Environment Variables
# ============================================
# Copy this file to .env and edit as needed.
# All values have sensible defaults in server.js.

# Server
PORT=3001

# Database (SQLite file path)
DB_PATH=./apc_data.db

# MQTT Broker (HiveMQ Cloud)
MQTT_HOST=492260d5d94c4b4e87ade94ae81925e6.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USER=sus-dashboard
MQTT_PASS=SuS-Mqtt#2026!Secure
MQTT_TOPIC=bus/#

# Bus capacity (used for occupancy % calculation)
BUS_CAPACITY=55

# Set to any value to enable SQLite query logging
# DB_VERBOSE=1
